rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-hiker packing & shopping lists
    // Structure: hikers/{hikerId}/packing/{itemId}
    //            hikers/{hikerId}/shopping/{itemId}
    match /hikers/{hikerId}/{listType}/{itemId} {
      allow read, write: if request.auth != null;
    }

    // Legacy (can be removed once old data is migrated)
    match /lists/{listId}/items/{itemId} {
      allow read, write: if request.auth != null;
    }
  }
}
